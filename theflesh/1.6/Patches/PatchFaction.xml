<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Royalty</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>
                <li Class="PatchOperationReplace">
                    <xpath>Defs/FactionDef[defName="SWBioDivision"]/allowedCultures</xpath>
                    <value>
                        <allowedCultures>
                            <li MayRequire="Ludeon.Rimworld.Ideology">Sophian</li>
                        </allowedCultures>
                    </value>
                </li>
            </operations>
        </match>
    </Operation>
</Patch>