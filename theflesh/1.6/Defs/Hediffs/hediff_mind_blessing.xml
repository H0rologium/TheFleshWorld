      <li Class="HediffCompProperties_DisappearsOnDeath" />
      <li>
        <compClass>TheFlesh.HoraxBlessing</compClass>
      </li>
    </comps>
    <stages>
      <li>
        <painOffset>-0.44</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>2</offset>
          </li>
          <li>
            <capacity>Sight</capacity>
            <offset>2</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>