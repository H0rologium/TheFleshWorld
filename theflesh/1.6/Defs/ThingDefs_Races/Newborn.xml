<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ThingDef ParentName="BaseFleshbeast">
        <defName>tfNewborn</defName>
        <label>newborn</label>
        <description>A monstrous creature that resembles a massive, painfully swollen mound of mass with randomly reconfigured body parts. Near its top is a stretched face that watches its victim with dead eyes. While resembling a gorehulk, newborns have no developed organ to launch spikes, instead their newly twisted bodies excel at finding and lashing out at the nearest target. Letting the void turn you into a newborn is considered a horaxian honor.</description>
        <statBases>
        <MoveSpeed>6</MoveSpeed>
        <MinimumContainmentStrength>70</MinimumContainmentStrength>
        <ArmorRating_Sharp>0.1</ArmorRating_Sharp>
        <ArmorRating_Blunt>0.3</ArmorRating_Blunt>
        </statBases>
        <uiIconPath>Things/Pawn/Fleshbeast/Toughspike/Toughspike_MenuIcon</uiIconPath>
        <race>
        <body>tfNewbornBody</body>
        <baseBodySize>2</baseBodySize>
        <baseHealthScale>4</baseHealthScale>
        <lifeExpectancy>15</lifeExpectancy>
        <renderTree>Toughspike</renderTree>
        <canBecomeShambler>true</canBecomeShambler>
        <lifeStageAges>
        <li>
        <def>FullyFormed_Toughspike</def>
        <soundWounded>Pawn_Fleshbeast_Toughspike_Wounded</soundWounded>
        <soundDeath>Pawn_Fleshbeast_Toughspike_Death</soundDeath>
        <soundCall>Pawn_Fleshbeast_Toughspike_Call</soundCall>
        </li>
        </lifeStageAges>
        </race>
        <comps>
