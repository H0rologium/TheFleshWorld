<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <FactionDef ParentName="OutlanderRoughBase">
    <defName>SWBioDivision</defName>
    <label>starway Plasmid Division</label>
    <description>Unlike the main corporation, this division has arrived on the Rim in order to investigate disturbing reports of 'beasts made from flesh'. Cooperation is expected as the bio division works hard to help understand and eradicate this phonomena.</description>
    <pawnSingular>researcher</pawnSingular>
    <pawnsPlural>researchers</pawnsPlural>
    <leaderTitle>geneticist</leaderTitle>
    
    <settlementGenerationWeight>1</settlementGenerationWeight>
    <canSiege>false</canSiege>
    <canStageAttacks>false</canStageAttacks>
    <autoFlee>true</autoFlee>
    <techLevel>Spacer</techLevel>
    <factionIconPath>UI/SWFLogo</factionIconPath>
    <factionNameMaker>NamerFactionOutlander</factionNameMaker>
    <settlementNameMaker>NamerSettlementOutlander</settlementNameMaker>
    <naturalEnemy>true</naturalEnemy>

    <allowedCultures><li MayRequire="Ludeon.Rimworld.Ideology">Rustican</li></allowedCultures>
    <maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
    <requiredCountAtGameStart>1</requiredCountAtGameStart>


    <arrivalLayerWhitelist>
      <li>Surface</li>
      <li MayRequire="Ludeon.RimWorld.Odyssey">Orbit</li>
    </arrivalLayerWhitelist>
    <requiredMemes>
      <li MayRequire="Ludeon.RimWorld.Ideology">Collectivist</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">Loyalist</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">HumanPrimacy</li>
    </requiredMemes>
    <structureMemeWeights>
      <Structure_Archist MayRequire="Ludeon.RimWorld.Ideology">1</Structure_Archist>
    </structureMemeWeights>
    <xenotypeSet>
      <xenotypeChances>
        <Dirtmole MayRequire="Ludeon.RimWorld.Biotech">0.1</Dirtmole>
        <Waster MayRequire="Ludeon.RimWorld.Biotech">0.055</Waster>
        <Genie MayRequire="Ludeon.RimWorld.Biotech">0.2</Genie>
        <Yttakin MayRequire="Ludeon.RimWorld.Biotech">0.025</Yttakin>
        <Starjack MayRequire="Ludeon.RimWorld.Biotech,Ludeon.RimWorld.Odyssey">0.1</Starjack>
      </xenotypeChances>
    </xenotypeSet>
    <techLevel>Ultra</techLevel>
    <backstoryFilters>
      <li>
        <categories>
          <li>Offworld</li>
        </categories>
      </li>
    </backstoryFilters>
    <apparelStuffFilter>
      <stuffCategoriesToAllow>
        <li>Metallic</li>
        <li>Fabric</li>
      </stuffCategoriesToAllow>
      <disallowedThingDefs>
        <li>DevilstrandCloth</li>
      </disallowedThingDefs>
    </apparelStuffFilter>
    <allowedArrivalTemperatureRange>-40~45</allowedArrivalTemperatureRange>
    <settlementTexturePath>World/WorldObjects/Expanding/Town</settlementTexturePath>
    <colorSpectrum>
      <li>(131,193,209)</li>
    </colorSpectrum>
    <baseTraderKinds>
		    <li>Orbital_BulkGoods</li>
        <li>Orbital_CombatSupplier</li>
        <li>Orbital_Exotic</li>
	  </baseTraderKinds>
    <caravanTraderKinds>
      <li>Base_Outlander_Standard</li>
    </caravanTraderKinds>
    <raidCommonalityFromPointsCurve>
      <points>
        <li>(0, 1)</li> <!--Constant 1 at all points levels-->
      </points>
    </raidCommonalityFromPointsCurve>
    <raidLootMaker>OutlanderRaidLootMaker</raidLootMaker>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(500, 100)</li>
        <li>(1000, 150)</li>
        <li>(2000, 250)</li>
        <li>(2001, 10000)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>
    </FactionDef>
</Defs>